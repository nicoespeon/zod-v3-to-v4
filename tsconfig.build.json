{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "./src",
    // Prevents a stale cache from skipping emit after `prebuild` wipes dist.
    "incremental": false
  },
  "include": ["./src/**/*.ts", "./src/**/*.js"],
  "exclude": [
    "node_modules",
    "./dist/**/*",
    "./test/**/*",
    "./playground/**/*",
    "./playground-monorepo/**/*"
  ]
}
